    local bindBtn = Instance.new("TextButton")
    bindBtn.Size = UDim2.new(0, 50, 0, 24)
    bindBtn.Position = UDim2.new(1, -55, 0, 4)
    bindBtn.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
    bindBtn.Font = Enum.Font.GothamBold
    bindBtn.TextColor3 = Color3.fromRGB(200, 200, 200)
    bindBtn.TextSize = 10
    bindBtn.Text = (keybindKey and Keybinds[keybindKey] and Keybinds[keybindKey].Name) or "None"
    bindBtn.ZIndex = 4
    bindBtn.Parent = toggle
    Instance.new("UICorner", bindBtn).CornerRadius = UDim.new(0, 4)

    local enabled = false
    local waitingForKey = false

    local function setEnabled(state)
        enabled = state
        checkmark.Text = enabled and "✓" or ""
        checkbox.BackgroundColor3 = enabled and Color3.fromRGB(100, 180, 255) or Color3.fromRGB(30, 30, 30)
        if callback then callback(enabled) end
    end

    checkbox.MouseButton1Click:Connect(function() setEnabled(not enabled) end)

    bindBtn.MouseButton1Click:Connect(function()
        waitingForKey = true
        bindBtn.Text = "..."
    end)

    if keybindKey then
        ToggleCallbacks[keybindKey] = {
            toggle = function() setEnabled(not enabled) end,
            getKey = function() return Keybinds[keybindKey] end,
            setKeybind = function(keyCode)
                Keybinds[keybindKey] = keyCode
                bindBtn.Text = keyCode and keyCode.Name or "None"
            end
        }
        ToggleSetters[keybindKey .. "Enabled"] = function(state)
            if state ~= enabled then setEnabled(state) end
        end
        ToggleSetters[text:gsub(" ", "") .. "Enabled"] = function(state)
            if state ~= enabled then setEnabled(state) end
        end
    end

    safeConnect(UserInputService.InputBegan, function(input, gp)
        if waitingForKey and input.UserInputType == Enum.UserInputType.Keyboard and not gp then
            if input.KeyCode == Enum.KeyCode.Escape then
                if keybindKey then Keybinds[keybindKey] = nil end
                bindBtn.Text = "None"
            else
                if keybindKey then Keybinds[keybindKey] = input.KeyCode end
                bindBtn.Text = input.KeyCode.Name
            end
            waitingForKey = false
        end
    end)

    return toggle, setEnabled
end

local function createSlider(text, min, max, default, parent, callback, order)
    local sliderFrame = Instance.new("Frame")
    sliderFrame.Size = UDim2.new(1, 0, 0, 44)
    sliderFrame.BackgroundTransparency = 1
    sliderFrame.LayoutOrder = order
    sliderFrame.ZIndex = 3
    sliderFrame.Parent = parent

    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(1, -45, 0, 20)
    label.Position = UDim2.new(0, 4, 0, 0)
    label.BackgroundTransparency = 1
    label.TextColor3 = Color3.fromRGB(200, 200, 200)
    label.Font = Enum.Font.GothamSemibold
    label.TextSize = 13
    label.Text = text
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.ZIndex = 4
    label.Parent = sliderFrame

    local valueLabel = Instance.new("TextLabel")
    valueLabel.Size = UDim2.new(0, 40, 0, 20)
    valueLabel.Position = UDim2.new(1, -44, 0, 0)
    valueLabel.BackgroundTransparency = 1
    valueLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
    valueLabel.Font = Enum.Font.GothamBold
    valueLabel.TextSize = 13
    valueLabel.Text = tostring(default)
    valueLabel.ZIndex = 4
    valueLabel.Parent = sliderFrame

    local sliderHitArea = Instance.new("TextButton")
    sliderHitArea.Size = UDim2.new(1, -10, 0, 30)
    sliderHitArea.Position = UDim2.new(0, 5, 0, 14)
    sliderHitArea.BackgroundTransparency = 1
    sliderHitArea.Text = ""
    sliderHitArea.ZIndex = 3
    sliderHitArea.Parent = sliderFrame

    local sliderBg = Instance.new("Frame")
    sliderBg.Size = UDim2.new(1, 0, 0, 6)
    sliderBg.Position = UDim2.new(0, 0, 0.5, -3)
    sliderBg.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
    sliderBg.ZIndex = 3
    sliderBg.Parent = sliderHitArea
    Instance.new("UICorner", sliderBg).CornerRadius = UDim.new(0, 3)

    local sliderFill = Instance.new("Frame")
    sliderFill.Size = UDim2.new((default - min) / (max - min), 0, 1, 0)
    sliderFill.BackgroundColor3 = Color3.fromRGB(100, 180, 255)
    sliderFill.ZIndex = 4
    sliderFill.Parent = sliderBg
    Instance.new("UICorner", sliderFill).CornerRadius = UDim.new(0, 3)

    local sliderBtn = Instance.new("TextButton")
    sliderBtn.Size = UDim2.new(0, 28, 0, 28)
    sliderBtn.Position = UDim2.new((default - min) / (max - min), -14, 0.5, -14)
    sliderBtn.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
    sliderBtn.Text = ""
    sliderBtn.ZIndex = 5
    sliderBtn.Parent = sliderBg
    Instance.new("UICorner", sliderBtn).CornerRadius = UDim.new(1, 0)

    local function setValue(value)
        value = math.clamp(math.floor(value), min, max)
        local pos = (value - min) / (max - min)
        sliderFill.Size = UDim2.new(pos, 0, 1, 0)
        sliderBtn.Position = UDim2.new(pos, -14, 0.5, -14)
        valueLabel.Text = tostring(value)
        callback(value)
    end

    local function handleSliderInput(inputPos)
        local pos = math.clamp(
            (inputPos.X - sliderBg.AbsolutePosition.X) / sliderBg.AbsoluteSize.X,
            0, 1
        )
        setValue(min + (max - min) * pos)
    end

    local slider_dragging = false

    sliderBtn.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            slider_dragging = true
        end
    end)

    sliderHitArea.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            slider_dragging = true
            handleSliderInput(input.Position)
        end
    end)

    sliderBg.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            slider_dragging = true
            handleSliderInput(input.Position)
        end
    end)

    safeConnect(UserInputService.InputEnded, function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            slider_dragging = false
        end
    end)

    safeConnect(UserInputService.InputChanged, function(input)
        if slider_dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            handleSliderInput(input.Position)
        end
    end)

    return sliderFrame, setValue
end

