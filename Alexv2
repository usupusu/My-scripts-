local function findTargetPlayer()
    if TargetStrafeTargetName == "" then return nil end
    local search = TargetStrafeTargetName:lower()
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= LocalPlayer then
            if p.Name:lower():find(search) or (p.DisplayName and p.DisplayName:lower():find(search)) then
                return p
            end
        end
    end
    return nil
end

safeConnect(RunService.Heartbeat, function(dt)
    if not TargetStrafeEnabled then return end
    local targetPlayer = findTargetPlayer()
    if not targetPlayer or not targetPlayer.Character then return end
    local targetHRP = targetPlayer.Character:FindFirstChild("HumanoidRootPart")
    local myChar = LocalPlayer.Character
    local myHRP = myChar and myChar:FindFirstChild("HumanoidRootPart")
    if not targetHRP or not myHRP then return end
    local targetPos = targetHRP.Position
    local targetCFrame = targetHRP.CFrame
    local newPos
    if TargetBackstabEnabled then
        local backDirection = -targetCFrame.LookVector * TargetStrafeRadius
        newPos = targetPos + backDirection + Vector3.new(0, StrafeGroundOffset, 0)
    else
        strafeAngle = strafeAngle + (TargetStrafeSpeed * dt)
        local offsetX = math.cos(strafeAngle) * TargetStrafeRadius
        local offsetZ = math.sin(strafeAngle) * TargetStrafeRadius
        local newY = targetPos.Y + StrafeGroundOffset
        newPos = Vector3.new(targetPos.X + offsetX, newY, targetPos.Z + offsetZ)
    end
    local lookAt = Vector3.new(targetPos.X, myHRP.Position.Y, targetPos.Z)
    myHRP.CFrame = CFrame.new(newPos, lookAt)
    local myHum = myChar:FindFirstChildOfClass("Humanoid")
    if StrafeGroundOffset > 0 then
        if myHum then myHum.PlatformStand = true end
        myHRP.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
    else
        if myHum then myHum.PlatformStand = false end
    end
end)

local RoomCorners = {
    CFrame.new(-502.5840, 2.9586, -99.7188),
    CFrame.new(-549.8830, 2.9586, -97.9642),
    CFrame.new(-549.4838, 2.9586, -172.7903),
    CFrame.new(-502.7632, 2.9586, -172.8640)
}
local TeleportAuraLoop = nil

local function clampToRoomBounds(targetPos, radius)
    local minX = math.min(-502.5840, -549.8830, -549.4838, -502.7632)
    local maxX = math.max(-502.5840, -549.8830, -549.4838, -502.7632)
    local minZ = math.min(-99.7188, -97.9642, -172.7903, -172.8640)
    local maxZ = math.max(-99.7188, -97.9642, -172.7903, -172.8640)
    minX = minX + radius
    maxX = maxX - radius
    minZ = minZ + radius
    maxZ = maxZ - radius
    local clampedX = math.clamp(targetPos.X, minX, maxX)
    local clampedZ = math.clamp(targetPos.Z, minZ, maxZ)
    return Vector3.new(clampedX, targetPos.Y, clampedZ)
end

local function getRandomCorner()
    return RoomCorners[math.random(1, #RoomCorners)]
end

local startKillAura, stopKillAura

local function startTeleportAura()
    if TeleportAuraLoop then TeleportAuraLoop.disconnect() end
    _savedHitboxSize       = HitboxSize
    _savedKillAuraRange    = KillAuraRange
    _savedAttacksPerSecond = AttacksPerSecond
    HitboxSize       = 30
    KillAuraRange    = 50
    AttacksPerSecond = 3000
    if not KillAuraEnabled then
        _tpAuraStartedKillAura = true
        KillAuraEnabled = true
        startKillAura()
    else
        _tpAuraStartedKillAura = false
        startKillAura()
    end
    local loopActive = true
    TeleportAuraLoop = { disconnect = function() loopActive = false end }
    task.spawn(function()
        while loopActive and TeleportAuraEnabled do
            local char = LocalPlayer.Character
            local myHRP = char and char:FindFirstChild("HumanoidRootPart")
            if myHRP then
                local closestTarget = nil
                local closestDist = math.huge
                for _, plr in ipairs(Players:GetPlayers()) do
                    if plr == LocalPlayer or not plr.Character then continue end
                    if isFriend(plr.Name) or isFriend(plr.DisplayName) then continue end
                    if not isTarget(plr.Name) and not isTarget(plr.DisplayName) then continue end
                    local targetHRP = plr.Character:FindFirstChild("HumanoidRootPart")
                    local hum = plr.Character:FindFirstChildOfClass("Humanoid")
                    if targetHRP and hum and hum.Health > 0 then
                        local dist = (targetHRP.Position - myHRP.Position).Magnitude
                        if dist < closestDist then
                            closestDist = dist
                            closestTarget = targetHRP
                        end
                    end
                end
                if closestTarget then
                    local targetPos = closestTarget.Position
                    local randomHeight = math.random(TeleportAuraHeightMin * 10, TeleportAuraHeightMax * 10) / 10
                    local offsetAngle = math.random() * math.pi * 2
                    local offsetX = math.cos(offsetAngle) * TeleportAuraRadius
                    local offsetZ = math.sin(offsetAngle) * TeleportAuraRadius
                    local tpToPos = Vector3.new(targetPos.X + offsetX, targetPos.Y + randomHeight, targetPos.Z + offsetZ)
                    tpToPos = clampToRoomBounds(tpToPos, TeleportAuraRadius)
                    myHRP.CFrame = CFrame.new(tpToPos)
                    myHRP.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
                    task.wait()
                    local randomCorner = getRandomCorner()
                    myHRP.CFrame = randomCorner
                    myHRP.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
                end
            end
            local waitTime = (TeleportAuraDelay / 100) * 5
            if waitTime > 0 then
                task.wait(waitTime)
            else
                task.wait()
            end
        end
    end)
end

local function stopTeleportAura()
    if TeleportAuraLoop then
        TeleportAuraLoop.disconnect()
        TeleportAuraLoop = nil
    end
    TeleportAuraEnabled = false
    if _savedHitboxSize       then HitboxSize       = _savedHitboxSize       end
    if _savedKillAuraRange    then KillAuraRange    = _savedKillAuraRange    end
    if _savedAttacksPerSecond then AttacksPerSecond = _savedAttacksPerSecond end
    _savedHitboxSize       = nil
    _savedKillAuraRange    = nil
    _savedAttacksPerSecond = nil
    if _tpAuraStartedKillAura then
        KillAuraEnabled = false
        stopKillAura()
        _tpAuraStartedKillAura = false
    else
        if KillAuraEnabled then startKillAura() end
    end
end

