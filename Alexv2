    if input.KeyCode == Enum.KeyCode.Insert or input.KeyCode == Enum.KeyCode.LeftControl then
        MainFrame.Visible = not MainFrame.Visible
    end
    for k, data in pairs(ToggleCallbacks) do
        local kc = data.getKey and data.getKey()
        if kc and input.KeyCode == kc then data.toggle() end
    end
    if Keybinds.Respawn and input.KeyCode == Keybinds.Respawn then
        doRespawn()
    end
end)

