local auraLoop
local lastAttack = 0

startKillAura = function()
    if auraLoop then auraLoop:Disconnect() end
    lastAttack = 0
    auraLoop = RunService.Heartbeat:Connect(function()
        if not KillAuraEnabled or ScriptUnloaded then return end
        local now = tick()
        if now - lastAttack < (1 / AttacksPerSecond) then return end
        local char = LocalPlayer.Character
        if not char or not char:FindFirstChild("HumanoidRootPart") then return end
        local myPos = char.HumanoidRootPart.Position
        local targets = {}
        for _, plr in ipairs(Players:GetPlayers()) do
            if plr == LocalPlayer or not plr.Character then continue end
            if isFriend(plr.Name) or isFriend(plr.DisplayName) then continue end
            if not isTarget(plr.Name) and not isTarget(plr.DisplayName) then continue end
            local hrp = plr.Character:FindFirstChild("HumanoidRootPart")
            local hum = plr.Character:FindFirstChildOfClass("Humanoid")
            if hrp and hum and hum.Health > 0 then
                local dist = (hrp.Position - myPos).Magnitude
                if dist <= KillAuraRange then table.insert(targets, {char = plr.Character, dist = dist}) end
            end
        end
        table.sort(targets, function(a, b) return a.dist < b.dist end)
        if #targets == 0 then return end
        lastAttack = now
        for _, t in ipairs(targets) do
            task.spawn(function()
                pcall(function() if RE.PunchDoRemote then RE.PunchDoRemote:InvokeServer() end end)
                task.wait(0.001)
                pcall(function() local hum = t.char:FindFirstChildOfClass("Humanoid") if hum and RE.HitRemote then RE.HitRemote:InvokeServer(hum) end end)
            end)
        end
    end)
end

stopKillAura = function()
    if auraLoop then
        auraLoop:Disconnect()
        auraLoop = nil
    end
end

