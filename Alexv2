local function refreshKeybindDisplays()
    for k, keyCode in pairs(Keybinds) do
        if keyCode and ToggleCallbacks[k] and ToggleCallbacks[k].setKeybind then
            ToggleCallbacks[k].setKeybind(keyCode)
        end
    end
end

local ToggleSetters = {}
local SliderSetters = {}
local friendsTextRef = nil
local targetTextRef = nil
local strafeTargetBoxRef = nil

local function applyConfig(cfg)
    if not cfg then return end
    if cfg.sliders then
        for k, v in pairs(cfg.sliders) do
            if SliderSetters[k] then SliderSetters[k](v) end
        end
    end
    if cfg.friends and friendsTextRef then friendsTextRef.Text = cfg.friends end
    if cfg.targets and targetTextRef then targetTextRef.Text = cfg.targets end
    if cfg.strafeTarget and strafeTargetBoxRef then
        strafeTargetBoxRef.Text = cfg.strafeTarget
        TargetStrafeTargetName = cfg.strafeTarget
    end
    if cfg.keybinds then
        for k, vName in pairs(cfg.keybinds) do
            if vName and type(vName) == "string" then
                local ok, keyCode = pcall(function()
                    return Enum.KeyCode[vName]
                end)
                if ok and keyCode then
                    Keybinds[k] = keyCode
                end
            end
        end
    end
    if cfg.toggles then
        for k, v in pairs(cfg.toggles) do
            if ToggleSetters[k] then ToggleSetters[k](v) end
        end
    end
    refreshKeybindDisplays()
end

