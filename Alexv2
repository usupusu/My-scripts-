local isTarget, isFriend

isTarget = function(name)
    if #TargetNamesList == 0 then return true end
    local ln = name:lower()
    for _, t in ipairs(TargetNamesList) do
        if ln:find(t, 1, true) then return true end
    end
    return false
end

isFriend = function(name)
    local ln = name:lower()
    for _, f in ipairs(FriendsNamesList) do if ln:find(f, 1, true) then return true end end
    return false
end

