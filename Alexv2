    checkmark.BackgroundTransparency = 1
    checkmark.TextColor3 = Color3.fromRGB(100, 180, 255)
    checkmark.Font = Enum.Font.GothamBold
    checkmark.TextSize = 15
    checkmark.Text = ""
    checkmark.ZIndex = 5
