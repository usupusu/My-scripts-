local function startRainbow()
    if rainbowConnection then return end
    if not bioSet then
        UpdateBio:FireServer("")
        bioSet = true
    end
    local accumulatedBio = 0
    local accumulatedRP = 0
    local PHASE_OFFSET = 0.22
    rainbowConnection = RunService.RenderStepped:Connect(function(dt)
        local internalSpeed = RainbowSpeed * 0.05
        accumulatedBio = accumulatedBio + dt * internalSpeed
        accumulatedRP = accumulatedRP + dt * internalSpeed
        local hueBio = (accumulatedBio + PHASE_OFFSET) % 1
        local pastelBio = Color3.fromHSV(hueBio, 0.65, 0.98)
        local hueRP = accumulatedRP % 1
        local pastelRP = Color3.fromHSV(hueRP, 0.65, 0.98)
        UpdateBioColor:FireServer(pastelBio)
        UpdateRPColor:FireServer(pastelRP)
    end)
end

local function stopRainbow()
    if rainbowConnection then
        rainbowConnection:Disconnect()
        rainbowConnection = nil
    end
end

local function cleanRagdoll(character)
    if not character or not AntiRagdollEnabled then return end
    local humanoid = character:FindFirstChildOfClass("Humanoid")
    if humanoid then
        local badStates = {
            Enum.HumanoidStateType.Ragdoll,
            Enum.HumanoidStateType.Physics,
            Enum.HumanoidStateType.FallingDown,
            Enum.HumanoidStateType.PlatformStanding
        }
        for _, state in ipairs(badStates) do
            pcall(function() humanoid:SetStateEnabled(state, false) end)
        end
        humanoid.PlatformStand = false
    end
    local junk = {"RagdollJoints", "NoCollisions", "Local Ragdoll"}
    for _, name in ipairs(junk) do
        local obj = character:FindFirstChild(name)
        if obj then obj:Destroy() end
    end
    for _, obj in ipairs(character:GetDescendants()) do
        if (obj:IsA("BaseConstraint") or obj:IsA("Attachment")) and obj.Name:lower():find("ragdoll") then
            obj:Destroy()
        elseif obj:IsA("Motor6D") then
            obj.Enabled = true
        end
    end
end

