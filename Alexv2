local function doGrabTarget()
    if #TargetNamesList == 0 then return end
    if grabTargetIndex > #TargetNamesList then grabTargetIndex = 1 end
    local search = TargetNamesList[grabTargetIndex]
    grabTargetIndex = grabTargetIndex + 1
    local myChar = LocalPlayer.Character
    local myHRP = myChar and myChar:FindFirstChild("HumanoidRootPart")
    if not myHRP then return end
    local targetPlayer = nil
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= LocalPlayer then
            if p.Name:lower():find(search, 1, true) or (p.DisplayName and p.DisplayName:lower():find(search, 1, true)) then
                targetPlayer = p
                break
            end
        end
    end
    if not targetPlayer or not targetPlayer.Character then return end
    local targetHRP = targetPlayer.Character:FindFirstChild("HumanoidRootPart")
    if not targetHRP then return end
    local originalCFrame = myHRP.CFrame
    _arc_ignoreVelocity = true
    myHRP.CFrame = targetHRP.CFrame
    task.wait()
    pcall(function() GrabRF:InvokeServer() end)
    task.wait(0.1)
    myHRP.CFrame = originalCFrame
    task.spawn(function()
        local char = LocalPlayer.Character
        local hum = char and char:FindFirstChildOfClass("Humanoid")
        if hum then
            local timeout = tick() + 5
            while tick() < timeout do
                local state = hum:GetState()
                if state == Enum.HumanoidStateType.Running
                    or state == Enum.HumanoidStateType.RunningNoPhysics
                    or state == Enum.HumanoidStateType.Landed
                    or state == Enum.HumanoidStateType.None then
                    break
                end
                task.wait(0.05)
            end
        end
        task.wait(0.5)
        _arc_ignoreVelocity = false
    end)
end

local _arc_targetCFrame = CFrame.new(-502.844818, 10.1868954, -65.4427567, 0.560596228, 2.67291544e-09, -0.828089297, -2.95736768e-08, 1, -1.67928462e-08, 0.828089297, 3.39036497e-08, 0.560596228)
local _arc_safeCFrame   = _arc_targetCFrame + Vector3.new(0, 1, 0)

local _arc_connection              = nil
local _arc_originalCFrame          = nil
local _arc_originalCameraCFrame    = nil
local _arc_delay_time              = nil
local _arc_hasCleanedThisRagdoll   = false
local _arc_returnTask              = nil
local _arc_last_zero_to_nonzero    = nil
local _arc_was_zero_velocity       = false

local function _arc_countDisabledMotors(char)
    if not char then return 0, 0 end
    local total, disabled = 0, 0
    for _, obj in ipairs(char:GetDescendants()) do
        if obj:IsA("Motor6D") then
            total += 1
            if not obj.Enabled then disabled += 1 end
        end
    end
    return total, disabled
end

local function _arc_forceEndRagdoll(char)
    if not char then return end
    local humanoid = char:FindFirstChildOfClass("Humanoid")
    if humanoid then
        for _, state in ipairs({
            Enum.HumanoidStateType.Ragdoll,
            Enum.HumanoidStateType.Physics,
            Enum.HumanoidStateType.FallingDown,
            Enum.HumanoidStateType.PlatformStanding
        }) do
            pcall(function() humanoid:SetStateEnabled(state, false) end)
        end
        humanoid.PlatformStand = false
        humanoid:ChangeState(Enum.HumanoidStateType.GettingUp)
    end
    for _, n in ipairs({"RagdollJoints", "NoCollisions", "Local Ragdoll"}) do
        local obj = char:FindFirstChild(n)
        if obj then obj:Destroy() end
    end
    for _, obj in ipairs(char:GetDescendants()) do
        if obj:IsA("Motor6D") then
            obj.Enabled = true
        elseif (obj:IsA("BaseConstraint") or obj:IsA("Attachment")) and obj.Name:lower():find("ragdoll") then
            obj:Destroy()
        end
    end
end

local function _arc_onCharacterAdded(char)
    local hrp = char:WaitForChild("HumanoidRootPart", 10)
    if not hrp then return end
    if _arc_connection then _arc_connection:Disconnect() _arc_connection = nil end
    _arc_originalCFrame        = nil
    _arc_originalCameraCFrame  = nil
    _arc_delay_time            = nil
    _arc_hasCleanedThisRagdoll = false
    if _arc_returnTask then task.cancel(_arc_returnTask) _arc_returnTask = nil end
    _arc_last_zero_to_nonzero  = nil
    _arc_was_zero_velocity     = false
    task.wait(2.5)
    if not AntiRagComboEnabled then return end
    _arc_connection = RunService.Heartbeat:Connect(function()
        if not AntiRagComboEnabled then return end
        if not char.Parent or not hrp.Parent then
            if _arc_connection then _arc_connection:Disconnect() _arc_connection = nil end
            return
        end
        local hrp_vel     = hrp.AssemblyLinearVelocity
        local mag         = hrp_vel.Magnitude
        local y_vel       = hrp_vel.Y
        local is_zero_vel = (mag < 1e-6) and (math.abs(y_vel) < 1e-6)
        if _arc_was_zero_velocity and not is_zero_vel then
            if not _arc_ignoreVelocity then
                _arc_last_zero_to_nonzero = tick()
            end
        end
        _arc_was_zero_velocity = is_zero_vel
        local total, disabled = _arc_countDisabledMotors(char)
        local isRagdolled     = total >= 12 and (disabled / total) >= 0.9
        if isRagdolled then
            if not _arc_originalCFrame then
                _arc_originalCFrame = hrp.CFrame
                _arc_originalCameraCFrame = Camera.CFrame
                local now = tick()
                _arc_delay_time = 0.1
                if _arc_last_zero_to_nonzero and (now - _arc_last_zero_to_nonzero) < 1 then
                    _arc_delay_time = 3.5
                end
            end
            hrp.CFrame = _arc_safeCFrame
            if not _arc_hasCleanedThisRagdoll then
                _arc_forceEndRagdoll(char)
                _arc_hasCleanedThisRagdoll = true
            end
        else
            if _arc_originalCFrame and not _arc_returnTask then
                _arc_returnTask = task.delay(_arc_delay_time, function()
                    if hrp and hrp.Parent and _arc_originalCFrame then
                        hrp.CFrame = _arc_originalCFrame
                        if _arc_originalCameraCFrame then
                            Camera.CFrame = _arc_originalCameraCFrame
                        end
                        task.delay(0.05, function()
                            if hrp and hrp.Parent then
                                hrp.AssemblyLinearVelocity = Vector3.new(0, -1, 0)
                            end
                        end)
                    end
                    _arc_originalCFrame       = nil
                    _arc_originalCameraCFrame = nil
                    _arc_delay_time           = nil
                    _arc_returnTask           = nil
                end)
            end
            _arc_hasCleanedThisRagdoll = false
        end
    end)
end

